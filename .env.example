# ==========================================
# Forecast AI Environment Variables Template
# ==========================================
# Copy this file to .env or set variables in your deployment platform (Railway, Render, etc.)

# ------------------------------------------
# LLM Provider API Keys (At least one recommended)
# ------------------------------------------
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
OLLAMA_API_BASE=http://localhost:11434

# ------------------------------------------
# Kalshi & Robinhood Predict Market Data API
# ------------------------------------------
KALSHI_API_BASE_URL=https://api.elections.kalshi.com/trade-api/v2
KALSHI_API_KEY=optional_kalshi_api_key_here

# ------------------------------------------
# Polymarket Read-Only Market Data API
# ------------------------------------------
POLYMARKET_GAMMA_API_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_API_URL=https://clob.polymarket.com

# ------------------------------------------
# Robinhood Agentic Trading MCP Execution
# ------------------------------------------
ROBINHOOD_MCP_ENDPOINT=https://agent.robinhood.com/mcp/trading

# ------------------------------------------
# API Server Configuration
# ------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=30000
SERVER_API_KEY=optional_server_api_key_here

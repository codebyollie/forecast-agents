{
  "name": "Forecast AI Agents Devcontainer",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bullseye",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {}
  },
  "postCreateCommand": "pip install -e \".[ws,dev]\" && cd forecast-ui && npm install",
  "forwardPorts": [30000, 5173],
  "portsAttributes": {
    "30000": {
      "label": "FastAPI Server & Surveillance",
      "onAutoForward": "notify"
    },
    "5173": {
      "label": "Forecast UI Dashboard",
      "onAutoForward": "notify"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  }
}
